# ===========================================
# Frontend Environment — Example
# ===========================================
# Copy to .env.local for development.
# All variables use the VITE_ prefix (exposed to client via Vite).
#
# NEVER put API keys or secrets here. Production API calls go through
# the backend proxy (see VITE_API_PROXY_URL).

# Optional dev server overrides (useful in restricted environments).
# VITE_DEV_HOST=127.0.0.1
# VITE_DEV_PORT=3000

# ===========================================
# API PROXY (required in production)
# ===========================================
# In production, all external API calls go through the backend proxy.
# In dev, you can call APIs directly via VITE_GEMINI_API_KEY (optional).
VITE_API_PROXY_URL=
# Governance UI write token (frontend sends this as Bearer for RBAC mutations).
# For local demos only; production should use a secure auth flow.
VITE_GOVERNANCE_BEARER_TOKEN=
VITE_IPFS_WRITE_MODE=none
VITE_IPFS_PROXY_URL=

# Dev-only direct API access (NOT used in production)
VITE_GEMINI_API_KEY=
VITE_IPFS_API_KEY=
VITE_IPFS_PINNING_JWT=

# ===========================================
# BLOCKCHAIN
# ===========================================
VITE_BLOCKCHAIN_NETWORK=polygon-amoy
VITE_CHAIN_ID=80002
VITE_BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
VITE_GAS_LIMIT=300000
VITE_MAX_GAS_PRICE=50

# Smart Contract Addresses
VITE_CREDENTIAL_REGISTRY_CONTRACT=
VITE_DID_REGISTRY_CONTRACT=
VITE_GOVERNANCE_CONTRACT=

# Validator Addresses
VITE_VALIDATOR_ADDRESS_1=
VITE_VALIDATOR_ADDRESS_2=

# ===========================================
# IPFS
# ===========================================
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs/
VITE_IPFS_API_URL=https://api.pinata.cloud/pinning/pinFileToIPFS
VITE_IPFS_STATUS_LIST_CID=

# ===========================================
# SECURITY
# ===========================================
VITE_MFA_ENABLED=true
VITE_MFA_REQUIRED_FACTORS=2
VITE_MFA_SESSION_TIMEOUT=3600000
VITE_ALLOW_CLIENT_SIGNING=false
VITE_STRICT_DID_RESOLUTION=true
VITE_TURNSTILE_SITE_KEY=
VITE_CORS_ORIGIN=http://localhost:3000

# ===========================================
# RESEARCH PAPER FEATURES (NEW)
# ===========================================
# Deprecated (JWT signing now happens on backend only)
VITE_JWT_EXPIRATION=24h
VITE_JWT_ISSUER=morningstar-credentials

# QR Code Configuration
VITE_APP_URL=http://localhost:5173
VITE_QR_CODE_SIZE=300
VITE_QR_ERROR_CORRECTION=H

# Email Service (Production: use SendGrid/AWS SES)
VITE_EMAIL_SERVICE=console
VITE_EMAIL_FROM=noreply@morningstar-credentials.io
VITE_SENDGRID_API_KEY=
VITE_AWS_SES_REGION=
VITE_AWS_SES_ACCESS_KEY=
VITE_AWS_SES_SECRET_KEY=

# Performance Monitoring
VITE_PERFORMANCE_MONITORING_ENABLED=true
VITE_METRICS_EXPORT_INTERVAL=300000

# Channel Service (Hyperledger-inspired)
VITE_CHANNELS_ENABLED=true
VITE_DEFAULT_CHANNEL_TYPE=private

# Serial Number Configuration
VITE_SERIAL_NUMBER_PREFIX=MC
VITE_SERIAL_CHECKSUM_ENABLED=true

# ===========================================
# GDPR
# ===========================================
VITE_DPO_EMAIL=dpo@localhost
VITE_PRIVACY_CONTACT=privacy@localhost
VITE_COOKIE_CONSENT_REQUIRED=false
VITE_ANALYTICS_ENABLED=false

# ===========================================
# MONITORING
# ===========================================
VITE_SENTRY_DSN=
VITE_MONITORING_ENABLED=false
VITE_ERROR_REPORTING=false

# ===========================================
# FEATURE FLAGS
# ===========================================
VITE_ZKP_ENABLED=false
VITE_ZKP_CIRCUIT_PATH=/circuits/credential_verification
VITE_DUAL_CHAIN_ENABLED=false
VITE_PRIVATE_CHAIN_RPC=
VITE_BATCH_ISSUANCE_ENABLED=true
VITE_CREDENTIAL_REVOCATION_ENABLED=true
VITE_AUDIT_TRAIL_ENABLED=false
VITE_STATUS_LIST_LENGTH=131072
VITE_VC_ENGINE=auto
# Wallet connection: auto (real if available, mock otherwise), always (mock), never (require real wallet)
# Production recommendation: never
VITE_WALLET_MOCK_MODE=auto

# ===========================================
# CDN / ASSETS
# ===========================================
VITE_CDN_URL=
VITE_STATIC_ASSETS_URL=

# ===========================================
# REGISTRIES
# ===========================================
VITE_GOVERNANCE_REGISTRY_URL=
VITE_SCHEMA_REGISTRY_URL=

# ===========================================
# BACKEND EMAIL (for backend/.env)
# ===========================================
# When running `cd backend && npm start`, place these in backend/.env.
# EMAIL_TRANSPORT_MODE:
#   auto - use SMTP when fully configured, otherwise mock delivery
#   smtp - require SMTP and fail when credentials/config are invalid
#   mock - always mock delivery (no SMTP calls)
EMAIL_TRANSPORT_MODE=auto

# SMTP provider presets (currently supports SendGrid defaults).
SMTP_PROVIDER=sendgrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey

# SendGrid API key goes in SMTP_PASSWORD.
SMTP_PASSWORD=

# Required sender identity for outbound messages.
SMTP_FROM=noreply@morningstar-credentials.io

# Backend write-route authorization (backend/.env)
#   off      - no bearer token required (development only)
#   required - bearer token required for protected routes (recommended)
API_AUTH_MODE=required
API_ISSUER_TOKEN=
API_GOVERNANCE_TOKEN=
API_ADMIN_TOKEN=
AUTH_TOKEN_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_SESSION_TTL_SECONDS=86400
ALLOW_MOCK_WALLET_BINDING=true
EXPOSE_EMAIL_HEALTH_DETAILS=false

# Student verification security controls (backend/.env)
STUDENT_OTP_TTL_SECONDS=300
STUDENT_OTP_MAX_ATTEMPTS=5
RISK_SCORE_STEPUP_THRESHOLD=70
UNIVERSITY_DOMAIN_DATASET_URL=https://raw.githubusercontent.com/Hipo/university-domains-list/master/world_universities_and_domains.json
UNIVERSITY_ALLOWED_DOMAINS=
DISPOSABLE_EMAIL_DOMAINS=
DISPOSABLE_DOMAIN_BLOCKLIST_URL=

# Bot defense (Cloudflare Turnstile)
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false
# Production recommendation:
# TURNSTILE_REQUIRED=true

# Backend API performance/security controls (backend/.env)
# HOST controls the interface the backend binds to.
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=1
JSON_BODY_LIMIT=512kb
EXTERNAL_API_TIMEOUT_MS=20000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_CREDENTIALS=3600000
RATE_LIMIT_MAX_CREDENTIAL_ISSUANCE=15
RATE_LIMIT_WINDOW_MFA=900000
RATE_LIMIT_MAX_MFA_ATTEMPTS=5
RATE_LIMIT_WINDOW_AUTH_SESSIONS=900000
RATE_LIMIT_MAX_AUTH_SESSIONS=20
RATE_LIMIT_WINDOW_AUTH_OTP=900000
RATE_LIMIT_MAX_AUTH_OTP=10
RATE_LIMIT_WINDOW_AUTH_ROLE=900000
RATE_LIMIT_MAX_AUTH_ROLE=20
RATE_LIMIT_WINDOW_EXTERNAL=60000
RATE_LIMIT_MAX_EXTERNAL_REQUESTS=30
RATE_LIMIT_WINDOW_DID_WRITES=60000
RATE_LIMIT_MAX_DID_WRITES=25
RATE_LIMIT_WINDOW_GOVERNANCE_WRITES=60000
RATE_LIMIT_MAX_GOVERNANCE_WRITES=25
RATE_LIMIT_WINDOW_BLOCKCHAIN_WRITES=60000
RATE_LIMIT_MAX_BLOCKCHAIN_WRITES=40
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
REQUEST_TIMEOUT_MS=30000
MAX_REQUESTS_PER_SOCKET=1000
SLOW_REQUEST_THRESHOLD_MS=800
ENABLE_RESPONSE_COMPRESSION=true
RESPONSE_COMPRESSION_MIN_BYTES=1024
HEALTH_CACHE_MAX_AGE_SECONDS=5
REQUEST_LOGS=false
