# ===========================================
# Backend Server Environment — Example
# ===========================================
# Copy to backend/.env and fill in real values.
# NEVER commit backend/.env — it contains production secrets.

# ===========================================
# API KEYS
# ===========================================
GEMINI_API_KEY=your_gemini_api_key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# ===========================================
# BLOCKCHAIN (server-side RPC — may contain API key)
# ===========================================
BLOCKCHAIN_RPC_URL=https://polygon-mainnet.infura.io/v3/your_infura_key

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/morningstar_credentials
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ===========================================
# AUTH & SESSIONS
# ===========================================
AUTH_TOKEN_SECRET=generate_a_secure_random_string
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_SESSION_TTL_SECONDS=86400
ALLOW_MOCK_WALLET_BINDING=true

# Student verification controls
STUDENT_OTP_TTL_SECONDS=300
STUDENT_OTP_MAX_ATTEMPTS=5
RISK_SCORE_STEPUP_THRESHOLD=70
UNIVERSITY_DOMAIN_DATASET_URL=https://raw.githubusercontent.com/Hipo/university-domains-list/master/world_universities_and_domains.json
UNIVERSITY_ALLOWED_DOMAINS=
DISPOSABLE_EMAIL_DOMAINS=
DISPOSABLE_DOMAIN_BLOCKLIST_URL=

# Cloudflare Turnstile (bot defense)
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false
# Production recommendation:
# TURNSTILE_REQUIRED=true

# ===========================================
# MONITORING (server-side)
# ===========================================
SENTRY_DSN=
LOG_LEVEL=info
LOG_FORMAT=json
APM_ENABLED=false
TRACE_SAMPLE_RATE=0.1

# ===========================================
# SMS / TWILIO
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# EMAIL / SMTP
# ===========================================
# EMAIL_TRANSPORT_MODE:
#   auto - use SMTP when fully configured, otherwise mock delivery
#   smtp - require SMTP and fail when credentials/config are invalid
#   mock - always mock delivery (no SMTP calls)
EMAIL_TRANSPORT_MODE=smtp

# SendGrid provider defaults:
SMTP_PROVIDER=sendgrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey

# SendGrid API key:
SMTP_PASSWORD=

# Verified sender identity:
SMTP_FROM=Morningstar Credentials <noreply@your-verified-domain.com>

# ===========================================
# API ENDPOINT AUTHORIZATION
# ===========================================
# Protect mutating backend routes (/api/did*, /api/governance/institutions*, /api/blockchain/*, /api/email/notify, /api/mfa/send-otp).
#   off      - no bearer token required (development only)
#   required - bearer token required for protected routes (recommended)
API_AUTH_MODE=required

# One or more comma-separated bearer tokens per role.
# admin tokens bypass role checks for protected routes.
API_ISSUER_TOKEN=
API_GOVERNANCE_TOKEN=
API_ADMIN_TOKEN=

# Expose detailed SMTP config in /api/email/health.
# Keep false in production unless you have a trusted admin-only caller.
EXPOSE_EMAIL_HEALTH_DETAILS=false

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_CREDENTIAL_ISSUANCE=10
RATE_LIMIT_WINDOW_AUTH_SESSIONS=900000
RATE_LIMIT_MAX_AUTH_SESSIONS=20
RATE_LIMIT_WINDOW_AUTH_OTP=900000
RATE_LIMIT_MAX_AUTH_OTP=10
RATE_LIMIT_WINDOW_AUTH_ROLE=900000
RATE_LIMIT_MAX_AUTH_ROLE=20
RATE_LIMIT_WINDOW_EXTERNAL=60000
RATE_LIMIT_MAX_EXTERNAL_REQUESTS=30
RATE_LIMIT_WINDOW_DID_WRITES=60000
RATE_LIMIT_MAX_DID_WRITES=25
RATE_LIMIT_WINDOW_GOVERNANCE_WRITES=60000
RATE_LIMIT_MAX_GOVERNANCE_WRITES=25
RATE_LIMIT_WINDOW_BLOCKCHAIN_WRITES=60000
RATE_LIMIT_MAX_BLOCKCHAIN_WRITES=40

# ===========================================
# DATA RETENTION (days)
# ===========================================
CONSENT_RETENTION_DAYS=730
AUDIT_LOG_RETENTION_DAYS=2555
CREDENTIAL_CACHE_DAYS=90

# ===========================================
# SERVER
# ===========================================
PORT=3001
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000
SSL_CERT_PATH=
SSL_KEY_PATH=
JSON_BODY_LIMIT=512kb
EXTERNAL_API_TIMEOUT_MS=20000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
REQUEST_TIMEOUT_MS=30000
MAX_REQUESTS_PER_SOCKET=1000
SLOW_REQUEST_THRESHOLD_MS=800
ENABLE_RESPONSE_COMPRESSION=true
RESPONSE_COMPRESSION_MIN_BYTES=1024
HEALTH_CACHE_MAX_AGE_SECONDS=5
NODE_ENV=development
